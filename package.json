{
  "name": "mole-desktop",
  "version": "1.0.3",
  "description": "Mole — Windows 维护工具桌面版 (清理/项目产物/系统监控/磁盘浏览/系统优化/应用卸载)",
  "author": "Mole Desktop",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-backend": "python scripts/build.py",
    "dist": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.mole.desktop",
    "productName": "Mole",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "updater.js"],
    "extraResources": [
      { "from": "python/pkg/server", "to": "server", "filter": ["**/*"] },
      { "from": "assets/icon.ico", "to": "icon.ico" }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "deleteAppDataOnUninstall": true,
      "installerLanguages": ["zh-CN", "en-US", "ja"]
    },
    "publish": [
      { "provider": "github", "owner": "shushuitie2017", "repo": "mole-desktop" }
    ]
  }
}
